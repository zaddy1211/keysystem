-- ==================== TIMEOUT-SAFE REQUEST ====================
local function safeHttpGet(url, timeout)
    timeout = timeout or CHECK_TIMEOUT
    local result, err
    local done = false

    task.spawn(function()
        local ok, resp = pcall(HttpService.GetAsync, HttpService, url)
        if not done then
            if ok then result = resp else err = resp end
            done = true
        end
    end)

    local start = tick()
    while not done and (tick() - start) < timeout do
        task.wait(0.08)
    end
    done = true

    if not result and not err then
        return nil, "TIMEOUT"
    end
    return result, err
end

-- ==================== KEY VALIDATION (with timeout) ====================
local function validateKeyDirect(key)
    if not key or key == "" then
        return false, false, "No key provided"
    end

    local hwid = "unknown"
    pcall(function() hwid = game:GetService("RbxAnalyticsService"):GetClientId() end)

    local url = KEY_SYSTEM_URL .. "/api/check?key=" .. HttpService:UrlEncode(key) .. "&hwid=" .. HttpService:UrlEncode(hwid)

    local response, httpErr = safeHttpGet(url, CHECK_TIMEOUT)

    if httpErr == "TIMEOUT" then
        return false, false, "TIMEOUT"
    end
    if httpErr then
        return false, false, "Connection error: " .. tostring(httpErr)
    end
    if not response then
        return false, false, "No response from server"
    end

    local data
    local ok = pcall(function() data = HttpService:JSONDecode(response) end)
    if not ok or not data then
        return false, false, "Bad server response"
    end

    if data.valid then
        return true, data.permanent == true, data.message or "Key valid"
    else
        return false, false, data.message or "Invalid or expired key"
    end
end

-- ==================== SAVE/LOAD ====================
local function saveValidKey(key, isPerm)
    pcall(function()
        if writefile then
            writefile(SAVE_FILE, HttpService:JSONEncode({
                key = key, permanent = isPerm == true, savedAt = os.time()
            }))
        end
    end)
end

local function loadSavedKey()
    if not (isfile and readfile and isfile(SAVE_FILE)) then return nil end
    local raw = readfile(SAVE_FILE)
    if not raw or raw == "" then return nil end
    local ok, data = pcall(HttpService.JSONDecode, HttpService, raw)
    if ok and type(data) == "table" and data.key then return data.key end
    if #raw > 5 then return raw:gsub("%s+", "") end
    return nil
end

