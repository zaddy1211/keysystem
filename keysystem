    local function resetButtons()
        checking = false
        CheckBtn.Visible = true
        RetryBtn.Visible = false
        CheckBtn.Text = "Check Key"
        CheckBtn.BackgroundColor3 = C.Accent
        TimerLabel.Visible = false
        TimerLabel.Text = ""
    end

    local function startCheck(enteredKey)
        if checking then return end
        currentKeyAttempt = enteredKey

        checking = true
        CheckBtn.Visible = true
        RetryBtn.Visible = false
        CheckBtn.Text = "Checking..."
        CheckBtn.BackgroundColor3 = C.Loading
        Status.Text = "Verifying key with server..."
        Status.TextColor3 = C.TextSub
        TimerLabel.Visible = true
        TimerLabel.Text = "Connecting..."

        local startTime = tick()

        -- Live timer
        local timerConn
        timerConn = task.spawn(function()
            while checking do
                local elapsed = math.floor(tick() - startTime)
                if elapsed >= 1 then
                    TimerLabel.Text = "Still checking... (" .. elapsed .. "s / " .. math.floor(CHECK_TIMEOUT) .. "s max)"
                end
                task.wait(0.5)
            end
        end)

        task.spawn(function()
            local ok, valid, isPerm, msg = pcall(validateKeyDirect, enteredKey)

            task.defer(function()
                if timerConn then pcall(task.cancel, timerConn) end
                if not CheckBtn or not CheckBtn.Parent then return end

                if not ok then
                    resetButtons()
                    Status.Text = "Error: " .. tostring(valid)
                    Status.TextColor3 = C.Error
                    return
                end

                if msg == "TIMEOUT" then
                    -- TIMEOUT CASE
                    CheckBtn.Visible = false
                    RetryBtn.Visible = true
                    Status.Text = "Server is taking too long (slow response)"
                    Status.TextColor3 = C.Error
                    TimerLabel.Text = "Click Retry or try again later"
                    checking = false
                    return
                end

                if valid then
                    Status.Text = "✓ Key accepted" .. (isPerm and " (Permanent)" or "")
                    Status.TextColor3 = C.Success
                    TimerLabel.Text = "Loading..."
                    saveValidKey(enteredKey, isPerm)

                    task.delay(0.5, function()
                        if Screen and Screen.Parent then Screen:Destroy() end
                        if onSuccess then onSuccess(enteredKey, isPerm) end
                    end)
                else
                    resetButtons()
                    Status.Text = msg or "Invalid key"
                    Status.TextColor3 = C.Error
                end
            end)
        end)
    end

    CheckBtn.MouseButton1Click:Connect(function()
        local entered = (KeyBox.Text or ""):gsub("%s+", "")
        if entered == "" then
            Status.Text = "Please enter a key"
            Status.TextColor3 = C.Error
            return
        end
        startCheck(entered)
    end)

