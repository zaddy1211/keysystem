            dy = 43
        end

        New("TextLabel", {Parent = card, Position = UDim2.fromOffset(12,dy), Size = UDim2.new(0.6,-12,0,14), BackgroundTransparency = 1, Text = info.Desc, Font = Enum.Font.Gotham, TextSize = 9, TextColor3 = C.TextSub})

        local btn = New("TextButton", {Parent = card, AnchorPoint = Vector2.new(1,0.5), Position = UDim2.new(1,-10,0.5,0), Size = UDim2.fromOffset(80,30), BackgroundColor3 = C.BtnBG, Text = "LOAD", TextColor3 = C.BtnText, Font = Enum.Font.GothamBold, TextSize = 10})
        Corner(btn, 8)

        card.InputBegan:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseMovement then Tween(card, 0.12, {BackgroundColor3 = C.CardHover}) end end)
        card.InputEnded:Connect(function(inp) if inp.UserInputType == Enum.UserInputType.MouseMovement then Tween(card, 0.12, {BackgroundColor3 = C.CardBG}) end end)

        btn.MouseButton1Click:Connect(function()
            if loading then return end
            loading = true
            btn.Text = "..."
            Toast("Loading", "Fetching " .. info.Name .. "...")

            task.delay(0.2, function()
                local ok, src = pcall(function() return game:HttpGet(info.ScriptURL) end)
                if ok and src then
                    local fn, e = loadstring(src)
                    if fn then
                        Toast("Success", info.Name .. " loaded!")
                        task.delay(0.5, function()
                            if Screen.Parent then
                                Tween(Window, 0.2, {GroupTransparency = 1})
                                task.delay(0.2, function() if Screen.Parent then Screen:Destroy() end end)
                            end
                        end)
                        fn()
                    else
                        Toast("Error", "Compile: " .. tostring(e))
                        btn.Text = "RETRY"
                        loading = false
                    end
                else
                    Toast("Error", "Download failed")
                    btn.Text = "RETRY"
                    loading = false
                end
            end)
        end)
    end

    -- Open button
    local OpenBtn = New("ImageButton", {Parent = Screen, Name = "OpenButton", AnchorPoint = Vector2.new(0,0.5), Position = UDim2.new(0,14,0.5,0), Size = UDim2.fromOffset(40,40), BackgroundColor3 = C.CardBG, BackgroundTransparency = 0.04, Image = LOGO, Visible = false})
    Corner(OpenBtn, 10)
    New("UIStroke", {Parent = OpenBtn, Color = C.Accent, Transparency = 0.3, Thickness = 1.2})

    local winOpen = true
    local function SetOpen(o)
        winOpen = o
        if o then
            Window.Visible = true
            Window.GroupTransparency = 1
            Tween(Window, 0.22, {GroupTransparency = 0})
            OpenBtn.Visible = false
        else
            Tween(Window, 0.18, {GroupTransparency = 1})
            task.delay(0.18, function()
                if not winOpen and Window.Parent then Window.Visible = false; OpenBtn.Visible = true end
            end)
        end
    end

    MinBtn.MouseButton1Click:Connect(function() SetOpen(false) end)
    OpenBtn.MouseButton1Click:Connect(function() SetOpen(true) end)
    CloseBtn.MouseButton1Click:Connect(function()
        destroyed = true
        for _, c in ipairs(connections) do pcall(function() c:Disconnect() end) end
        Screen:Destroy()
    end)

    table.insert(connections, UserInputService.InputBegan:Connect(function(i)
        if i.KeyCode == Enum.KeyCode.RightControl or i.KeyCode == Enum.KeyCode.Insert then SetOpen(not winOpen) end
    end))

    -- Dragging
    local dr, ds, sp, di
    Topbar.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dr = true; ds = i.Position; sp = Window.Position end
    end)
    Topbar.InputChanged:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseMovement then di = i end end)
    table.insert(connections, UserInputService.InputChanged:Connect(function(i)
        if dr and i == di then
            local d = i.Position - ds
            Window.Position = UDim2.new(sp.X.Scale, sp.X.Offset + d.X, sp.Y.Scale, sp.Y.Offset + d.Y)
        end
    end))

    Window.GroupTransparency = 1
    Tween(Window, 0.3, {GroupTransparency = 0})

    task.delay(0.4, function()
        if not Screen.Parent then return end
        for _, info in ipairs(GameList) do if IsCurrent(info) then Toast("Detected", info.Name .. " — ready") return end end
        Toast("Lyra Loader", "Select a game")
    end)

    task.spawn(function() while true do task.wait(10) end end)
end

